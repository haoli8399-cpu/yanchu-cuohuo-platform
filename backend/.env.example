# Supabase 自托管部署 - 环境变量配置
# 复制此文件为 .env 并填写真实值

# ===== 数据库 =====
POSTGRES_PASSWORD=请替换为强密码

# ===== JWT =====
JWT_SECRET=请替换为至少32位随机字符串
ANON_KEY=请替换为Supabase生成
SERVICE_KEY=请替换为Supabase生成

# ===== 站点 =====
SITE_URL=http://localhost:3001

# ===== AI =====
DEEPSEEK_API_KEY=sk-请替换
DEEPSEEK_BACKUP_API_KEY=sk-请替换

# ===== 腾讯云 SMS =====
TENCENT_SMS_APP_ID=请替换
TENCENT_SMS_SECRET_ID=请替换
TENCENT_SMS_SECRET_KEY=请替换

# ===== 微信 =====
WECHAT_APP_ID=请替换
WECHAT_APP_SECRET=请替换
WECHAT_MINI_APP_ID=请替换
WECHAT_MINI_APP_SECRET=请替换
